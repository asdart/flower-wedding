{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Editorial",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs');const p=q.url==='/'?'/index.html':q.url;const f=require('path').join(process.cwd(),p);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');}else{r.writeHead(200,{'Content-Type':'text/html'});r.end(d);}});}).listen(3999)"],
      "port": 3999
    }
  ]
}